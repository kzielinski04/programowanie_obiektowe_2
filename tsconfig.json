{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "es2020",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "noImplicitAny": true,
    "strictNullChecks": true,
    "strict": true,
    "skipLibCheck": true,

    "jsx": "react-jsx",
    "isolatedModules": true
  },
  "include": ["src/**/*"]
}